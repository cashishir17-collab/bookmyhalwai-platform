rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function role() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role; }
    function admin() { return signedIn() && request.auth.token.phone_number == '+917291852535'; }
    function salesExecutive() { return signedIn() && role() == 'sales_executive'; }
    function ownsVendor(vendorId) { return signedIn() && get(/databases/$(database)/documents/vendors/$(vendorId)).data.userId == request.auth.uid; }
    function verifiedVendorConsent(consentId, phoneE164, salesExecutiveId, vendorUid) {
      return exists(/databases/$(database)/documents/vendorConsents/$(consentId))
        && get(/databases/$(database)/documents/vendorConsents/$(consentId)).data.status == 'verified'
        && get(/databases/$(database)/documents/vendorConsents/$(consentId)).data.phoneE164 == phoneE164
        && get(/databases/$(database)/documents/vendorConsents/$(consentId)).data.salesExecutiveId == salesExecutiveId
        && get(/databases/$(database)/documents/vendorConsents/$(consentId)).data.vendorUid == vendorUid
        && get(/databases/$(database)/documents/vendorConsents/$(consentId)).data.expiresAt > request.time;
    }
    match /vendors/{vendorId} {
      allow read: if resource.data.verificationStatus in ['Approved', 'Published', 'Verified']
        || admin()
        || (signedIn() && resource.data.userId == request.auth.uid)
        || (salesExecutive() && resource.data.salesExecutiveId == request.auth.uid);
      allow create: if admin()
        || (signedIn() && request.resource.data.userId == request.auth.uid)
        || (salesExecutive()
          && request.resource.data.salesExecutiveId == request.auth.uid
          && request.resource.data.userId == request.resource.data.ownerUid
          && request.resource.data.ownershipStatus == 'ownership_verified'
          && request.resource.data.verificationStatus == 'Pending'
          && verifiedVendorConsent(
            request.resource.data.vendorConsentId,
            request.resource.data.phoneE164,
            request.auth.uid,
            request.resource.data.ownerUid
          ));
      allow update: if admin()
        || (signedIn() && resource.data.userId == request.auth.uid)
        || (signedIn()
          && resource.data.userId == null
          && resource.data.ownershipStatus == 'otp_pending'
          && request.auth.token.phone_number == resource.data.phoneE164
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'userId', 'ownerUid', 'ownershipStatus', 'ownershipVerifiedAt', 'updatedAt'
          ])
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.ownershipStatus == 'ownership_verified');
    }
    match /enquiries/{enquiryId} {
      allow create: if signedIn() && role() == 'customer' && request.resource.data.customerId == request.auth.uid;
      allow read: if admin() || (signedIn() && (resource.data.customerId == request.auth.uid || resource.data.vendorOwnerId == request.auth.uid));
      allow update: if admin() || (signedIn() && (resource.data.customerId == request.auth.uid || resource.data.vendorOwnerId == request.auth.uid));
      allow delete: if admin();
    }
    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || admin());
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.role in ['customer', 'vendor'];
      allow update: if admin()
        || (signedIn()
          && request.auth.uid == userId
          && resource.data.role in ['customer', 'vendor', 'sales_executive']
          && request.resource.data.role == resource.data.role)
        || (signedIn()
          && request.auth.uid == userId
          && resource.data.role == 'customer'
          && request.resource.data.role == 'vendor'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'role', 'phoneNumber', 'birthDate', 'anniversaryApplicable',
            'anniversaryDate', 'updatedAt'
          ]));
    }

    match /vendorConsents/{consentId} {
      allow create: if signedIn()
        && request.resource.data.vendorUid == request.auth.uid
        && request.resource.data.phoneE164 == request.auth.token.phone_number
        && request.resource.data.status == 'verified'
        && request.resource.data.expiresAt > request.time;
      allow read: if admin()
        || (signedIn() && resource.data.vendorUid == request.auth.uid)
        || (salesExecutive() && resource.data.salesExecutiveId == request.auth.uid);
      allow update, delete: if admin();
    }
    match /systemCounters/vendorRegistration {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.lastCategory in [
          'halwai_caterer', 'decorator', 'tent_house', 'dj', 'photographer',
          'venue_banquet', 'makeup_artist', 'pandit', 'mehendi_artist',
          'return_gifts', 'choreographer'
        ]
        && request.resource.data.categoryCounters[request.resource.data.lastCategory].lastSequence == 1;
      allow update: if signedIn()
        && request.resource.data.lastCategory in [
          'halwai_caterer', 'decorator', 'tent_house', 'dj', 'photographer',
          'venue_banquet', 'makeup_artist', 'pandit', 'mehendi_artist',
          'return_gifts', 'choreographer'
        ]
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'categoryCounters', 'lastCategory', 'updatedAt'
        ])
        && request.resource.data.categoryCounters.diff(resource.data.categoryCounters).affectedKeys().hasOnly([
          request.resource.data.lastCategory
        ])
        && (
          (
            !(request.resource.data.lastCategory in resource.data.categoryCounters)
            && request.resource.data.categoryCounters[request.resource.data.lastCategory].lastSequence == 1
          )
          || (
            request.resource.data.categoryCounters[request.resource.data.lastCategory].currentYear
              == resource.data.categoryCounters[request.resource.data.lastCategory].currentYear
            && request.resource.data.categoryCounters[request.resource.data.lastCategory].lastSequence
              == resource.data.categoryCounters[request.resource.data.lastCategory].lastSequence + 1
          )
          || (
            request.resource.data.categoryCounters[request.resource.data.lastCategory].currentYear
              > resource.data.categoryCounters[request.resource.data.lastCategory].currentYear
            && request.resource.data.categoryCounters[request.resource.data.lastCategory].lastSequence == 1
          )
        );
      allow delete: if admin();
    }

    match /systemCounters/bookingReference {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.lastSequence == 1;
      allow update: if signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'currentYear', 'lastSequence', 'updatedAt'
        ])
        && (
          (
            request.resource.data.currentYear == resource.data.currentYear
            && request.resource.data.lastSequence == resource.data.lastSequence + 1
          )
          || (
            request.resource.data.currentYear > resource.data.currentYear
            && request.resource.data.lastSequence == 1
          )
        );
      allow delete: if admin();
    }

    match /partnerOnboarding/{registrationId} {
      allow create: if salesExecutive()
        && request.resource.data.salesExecutiveId == request.auth.uid
        && request.resource.data.status == 'ownership_verified'
        && request.resource.data.ownerUid != null
        && verifiedVendorConsent(
          request.resource.data.vendorConsentId,
          request.resource.data.phoneE164,
          request.auth.uid,
          request.resource.data.ownerUid
        );
      allow read: if admin()
        || (salesExecutive() && resource.data.salesExecutiveId == request.auth.uid)
        || (signedIn() && resource.data.ownerUid == request.auth.uid)
        || (signedIn() && request.auth.token.phone_number == resource.data.phoneE164);
      allow update: if admin()
        || (salesExecutive()
          && resource.data.salesExecutiveId == request.auth.uid
          && request.resource.data.salesExecutiveId == resource.data.salesExecutiveId
          && request.resource.data.ownerUid == resource.data.ownerUid)
        || (signedIn()
          && request.auth.token.phone_number == resource.data.phoneE164
          && resource.data.status == 'otp_pending'
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.phoneE164 == resource.data.phoneE164
          && request.resource.data.salesExecutiveId == resource.data.salesExecutiveId
          && request.resource.data.status == 'ownership_verified');
      allow delete: if admin();
    }
    match /supportTickets/{ticketId} {
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'open';
      allow read: if admin() || (signedIn() && resource.data.createdBy == request.auth.uid);
      allow update: if admin() || (signedIn()
        && resource.data.createdBy == request.auth.uid
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.status == resource.data.status);
      allow delete: if admin();
    }
    match /bookings/{bookingId} {
      allow create: if signedIn() && role() == 'customer' && request.resource.data.customerId == request.auth.uid;
      allow read, update: if admin() || (signedIn() && resource.data.customerId == request.auth.uid) || ownsVendor(resource.data.vendorId);
      allow delete: if admin();
    }
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if signedIn() && role() == 'customer' && request.resource.data.customerId == request.auth.uid && request.resource.data.verified == true;
      allow update, delete: if admin();
    }
    match /availability/{availabilityId} {
      allow read: if true;
      allow create: if admin() || (signedIn() && request.resource.data.ownerId == request.auth.uid);
      allow update: if admin() || (signedIn() && resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == request.auth.uid);
      allow delete: if admin() || (signedIn() && resource.data.ownerId == request.auth.uid);
    }
    match /{document=**} { allow read, write: if admin(); }
  }
}
